{
  "name": "i18n-ai-translator",
  "version": "0.0.1",
  "description": "LLM-based locale file synchronizer and translator",
  "type": "module",
  "keywords": [
    "i18n",
    "translation",
    "ai",
    "llm",
    "openai"
  ],
  "homepage": "https://github.com/Kafuu-Chinocya/i18n-ai-translator",
  "bugs": {
    "url": "https://github.com/Kafuu-Chinocya/i18n-ai-translator/issues"
  },
  "license": "MIT",
  "author": "Kafuu-Chinocya",
  "files": [
    "dist"
  ],
  "bin": {
    "i18n-ai-translator": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kafuu-Chinocya/i18n-ai-translator.git"
  },
  "scripts": {
    "prepare": "husky",
    "cz": "cz",
    "cli": "tsx src/index.ts",
    "translate": "tsx src/index.ts translate",
    "check": "tsx src/index.ts check",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.209",
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.4",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.15",
    "commitizen": "^4.3.2",
    "cz-git": "^1.13.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.8",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts}": "eslint --fix",
    "*.json": "prettier --write"
  }
}
